// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Validation stage — waitlist only

model WaitlistEntry {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("waitlist_entries")
}

// Analytics tracking
model PageView {
  id        String   @id @default(cuid())
  path      String
  userAgent String?
  ipAddress String?
  utmSource String?
  utmMedium String?
  utmCampaign String?
  createdAt DateTime @default(now())

  @@map("page_views")
}

// Email marketing infrastructure
model EmailSequence {
  id            String     @id @default(uuid())
  name          String
  triggerEvent  String
  subject       String
  body          String
  delayHours    Int        @default(0)
  sequenceOrder Int        @default(0)
  active        Boolean    @default(true)
  variant       String     @default("A")
  createdAt     DateTime   @default(now())
  emailLogs     EmailLog[]

  @@map("email_sequences")
}

model EmailLog {
  id         String         @id @default(uuid())
  sequenceId String
  sequence   EmailSequence  @relation(fields: [sequenceId], references: [id])
  recipient  String
  status     String         @default("sent")
  openedAt   DateTime?
  clickedAt  DateTime?
  sentAt     DateTime       @default(now())

  @@map("email_log")
}

